# -----------------------------
# Financial Modeling Prep API
# -----------------------------
FMP_API_KEY=your_fmp_api_key_here

# -----------------------------
# OpenAI API
# -----------------------------
OPENAI_API_KEY=your_openai_api_key_here

# Default OpenAI model used by AlphaLens
OPENAI_MODEL=gpt-4.1-mini

# -----------------------------
# AlphaLens defaults
# -----------------------------
DEFAULT_BENCHMARK_SYMBOL=SPY
DEFAULT_STATEMENT_LIMIT=5
DEFAULT_NEWS_LIMIT=10
DEFAULT_PRICE_HISTORY_DAYS=400

# FMP allows 750 requests/minute on your plan.
# Use a safety buffer below the hard limit.
FMP_MAX_REQUESTS_PER_MINUTE=700